{
  "name": "@orchestrator/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "predev": "pnpm --dir ../shared run build",
    "dev": "tsx watch src/index.ts",
    "prebuild": "pnpm --dir ../shared run build",
    "build": "tsc",
    "start": "node dist/index.js",
    "pretest": "pnpm --dir ../shared run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.2.10",
    "@orchestrator/shared": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
