# ============================================
# Orchestrator Monorepo .gitignore
# ============================================

# ─── Dependencies ───
node_modules/
**/node_modules/

# ─── Build Outputs ───
dist/
**/dist/
.turbo/
.vite/

# ─── TypeScript / Tooling Cache ───
*.tsbuildinfo
.cache/

# ─── Test Artifacts ───
coverage/
**/coverage/

# ─── Logs ───
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Environment Files ───
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ─── OS / Editor ───
.DS_Store
.idea/
.vscode/
